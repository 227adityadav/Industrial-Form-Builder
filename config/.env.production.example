# On your server: copy to the project root as `.env.production` (do not commit secrets to Git):
#   cp config/.env.production.example .env.production
#   nano .env.production
#
# Next.js loads `.env.production` when you run `npm start` (NODE_ENV=production).
# Use your real host: local mongod, Docker, or MongoDB Atlas (TLS).

MONGODB_URI=mongodb://127.0.0.1:27017/industrial-form-builder

SESSION_MAX_AGE_DAYS=7
# If nginx terminates HTTPS, you may not need to set this.
# COOKIE_SECURE=true
