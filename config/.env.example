# Copy to project root as `.env.local` and adjust.

# Optional: in development, if unset, an in-memory MongoDB is used (no install).
# For local mongod/Atlas, set e.g.:
# MONGODB_URI=mongodb://127.0.0.1:27017/industrial-form-builder
SESSION_MAX_AGE_DAYS=7

# ---- Production (VPS / `npm start`) ----
# A real MONGODB_URI is required (not optional). Copy and edit on the server only:
#   cp config/.env.production.example .env.production
# Set MONGODB_URI to your database; then `npm run build` and `npm start`.

# Debug (optional)
# AUTH_DEBUG=1                      # server: /api/auth/login structured logs (no passwords)
# NEXT_PUBLIC_AUTH_DEBUG=1          # browser: login fetch steps in devtools console
# COOKIE_SECURE=true|false          # force Set-Cookie Secure; omit = use X-Forwarded-Proto / URL (HTTP IP = non-secure cookies)
